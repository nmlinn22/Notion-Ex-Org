{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "express"],
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist"]
}
